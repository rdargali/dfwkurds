# ============================================
# Kurdish American Community Association
# Environment Variables Configuration
# ============================================
#
# Copy this file to .env.local for local development:
#   cp .env.sample .env.local
#
# ⚠️ CRITICAL: For production (Vercel), you MUST add these in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
#
# Without these variables, your site will show errors like:
#   "Dataset not found for project ID 'your-project-id'"
#

# ============================================
# REQUIRED: Sanity CMS Configuration
# ============================================
# Get your Project ID from: https://www.sanity.io/manage
# Select your project → Copy the Project ID

# For Next.js website (REQUIRED for production)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SANITY_DATASET=production

# For Sanity Studio (REQUIRED for local development)
# Sanity Studio automatically loads .env files and uses SANITY_STUDIO_ prefix
SANITY_STUDIO_PROJECT_ID=your-project-id-here
SANITY_STUDIO_DATASET=production

# ============================================
# OPTIONAL: On-Demand Cache Revalidation
# ============================================
# Only needed if you want automatic cache updates when publishing content
# Generate secret: openssl rand -hex 32
# REVALIDATE_SECRET=your-secret-token-here

# ============================================
# OPTIONAL: Other Settings
# ============================================
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# SANITY_API_TOKEN=your-api-token-here
# SANITY_APP_ID=your-app-id-here
