# ============================================
# Kurdish American Community Association
# Environment Variables Configuration
# ============================================
#
# Copy this file to .env.local for local development:
#   cp .env.sample .env.local
#
# For production (Vercel), add these in Project Settings → Environment Variables
#

# ============================================
# REQUIRED: Sanity CMS Configuration
# ============================================
# Get your Project ID from: https://www.sanity.io/manage
# Create a new project or use an existing one
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here

# Dataset name (usually 'production' for live site, 'development' for testing)
NEXT_PUBLIC_SANITY_DATASET=production

# ============================================
# OPTIONAL: Site Configuration
# ============================================
# Your production site URL (used for sitemap.xml and SEO)
# Example: https://dfwkurds.org or https://www.dfwkurds.org
# Leave empty to use default: https://dfwkurds.org
NEXT_PUBLIC_SITE_URL=https://dfwkurds.org

# ============================================
# OPTIONAL: Sanity API Token
# ============================================
# Only needed if you want to:
# - Write data to Sanity from the frontend
# - Use authenticated API requests
# - Access private datasets
#
# Generate token at: https://www.sanity.io/manage
# Go to your project → API → Tokens → Add API token
# SANITY_API_TOKEN=your-api-token-here

# ============================================
# Development vs Production
# ============================================
# NODE_ENV is automatically set by Next.js:
# - 'development' when running: npm run dev
# - 'production' when running: npm run build
# You typically don't need to set this manually

# ============================================
# Example Values (DO NOT USE IN PRODUCTION)
# ============================================
# NEXT_PUBLIC_SANITY_PROJECT_ID=abc123xyz
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SITE_URL=https://dfwkurds.vercel.app
# SANITY_API_TOKEN=skAbCdEfGhIjKlMnOpQrStUvWxYz1234567890
